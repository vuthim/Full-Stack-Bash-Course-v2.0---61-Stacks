# ===========================================
# Full Stack Bash Course - .gitignore
# ===========================================

# Course Progress (user-specific)
.progress
.bash_course_progress
*.progress

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# Backup files
*.bak
*.backup
*_backup*

# Log files (when running solutions)
*.log

# Cache directories
.cache/
.cache-*/*

# User-specific data
data/sample_data/users/
data/sample_data/private/
practice/Online_Course_By_Dave_Eddy/
practice/mypractices/

# Compiled scripts (if any)
*.o
*.pyc
__pycache__/

# IDE/Editor files
.vscode/
.idea/
*.sublime-*
*.sublime-project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Git files (in case root is different)
.git/
.gitattributes

# Certificates generated by the course
BASH_MASTER_CERTIFICATE.txt

# Temporary test outputs
test_output/
*.test.out
